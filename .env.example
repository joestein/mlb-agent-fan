# Copy to .env and fill in real values. .env is git-ignored; never commit secrets.

# Phoenix
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000

# Database
DATABASE_URL=ecto://postgres:postgres@localhost:5432/mlb_fan
# Postgres password for docker-compose (keep in sync with DATABASE_URL above)
POSTGRES_PASSWORD=postgres
# Optional Ecto pool size (default 10)
# POOL_SIZE=10

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-opus-4-8

# Exa.ai
EXA_API_KEY=your_exa_key
EXA_SEARCH_PRICE_USD=0.005
EXA_CONTENTS_PRICE_USD=0.001
EXA_SEARCH_TYPE=auto

# Cost control: soft per-session spend cap in USD (default 5.00). Once a
# session's combined Anthropic + Exa spend reaches this, further paid LLM
# turns are refused (cached answers still served free).
SESSION_SPEND_CAP_USD=5.00
